MONGODB_URI=mongodb://127.0.0.1:27017/glomaudit
MONGODB_DB=glomaudit

# Google PageSpeed Insights and Chrome UX Report (optional locally; required for
# reliable PageSpeed Overview / Core Web Vitals data in generated reports).
# You can use one Google API key for both services or provide separate keys.
PAGESPEED_API_KEY=
CRUX_API_KEY=
GOOGLE_API_KEY=

# 32 random bytes encoded as base64 or hex. Required in production.
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# Required when deploying this single-tenant workspace without a separate app
# sign-in system. Use the same values that own your saved integrations. For
# existing local demo connections, the user is usually `demo-user`; the project
# is the report ID from /report/<project-id>.
GLOMAUDIT_DEFAULT_USER_ID=
GLOMAUDIT_DEFAULT_PROJECT_ID=

# Existing one-off Search Console audit OAuth.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Multi-project integration OAuth callbacks.
GOOGLE_SEARCH_CONSOLE_REDIRECT_URI=http://localhost:3000/api/integrations/GOOGLE_SEARCH_CONSOLE/callback
GOOGLE_ANALYTICS_REDIRECT_URI=http://localhost:3000/api/integrations/GOOGLE_ANALYTICS/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_INTEGRATIONS_REDIRECT_URI=http://localhost:3000/api/integrations/BING_WEBMASTER/callback

# Optional deployment-specific Bing Webmaster API facade/base URL.
# Leave empty to expose Bing OAuth and unavailable metric states without fake imports.
BING_WEBMASTER_API_BASE=
